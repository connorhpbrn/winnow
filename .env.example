# --- Database ---
# Leave DATABASE_URL unset to use the in-process PGlite dev database (Postgres 16,
# persisted at .winnow/pgdata). No Docker or install needed.
# For hosted Supabase/Postgres, set DATABASE_URL. Migrations use the DIRECT connection (:5432);
# the app would use the pooler (:6543) in production.
# DATABASE_URL=postgresql://postgres:password@pooler-host:6543/postgres
# DATABASE_DIRECT_URL=postgresql://postgres:password@direct-host:5432/postgres

# --- OpenRouter (required for live model calls + Grok web/X research) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=https://winnow.to
OPENROUTER_APP_TITLE=Winnow

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Production HTTP / OAuth ---
# Railway public service URL, no trailing slash.
# PUBLIC_BASE_URL=https://your-service.up.railway.app
# PORT=8765
